# Django/web
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_SECRET_KEY_FILE=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
DJANGO_BEHIND_PROXY=true
# Set true only when TLS is terminated before the app/proxy and forwarded proto is preserved.
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_LOG_LEVEL=INFO
ML_SERVICE_URL=http://ml:8000

# Postgres
POSTGRES_DB=dsa
POSTGRES_USER=dsa
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql+psycopg2://dsa:replace-with-strong-db-password@postgres:5432/dsa
DATABASE_URL_FILE=

# Neo4j
NEO4J_AUTH=neo4j/replace-with-strong-neo4j-password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-strong-neo4j-password

# Graph/outbox
OUTBOX_BASE_URL=http://web:8000
OUTBOX_CONSUMER=graph
OUTBOX_AUTH_HEADER=
OUTBOX_TIMEOUT_SEC=10
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SEC=5
GRAPH_ENABLE_BACKGROUND_POLLER=false

# Optional integrations
ALGOLIA_APPLICATION_ID=replace-me
ALGOLIA_API_KEY=replace-me
ALGOLIA_INDEX_PREFIX=DSA
ML_SERVICE_TIMEOUT=2.5
