# Django/web
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_SECRET_KEY_FILE=
DJANGO_ALLOWED_HOSTS=example.com,localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,http://example.com
DJANGO_BEHIND_PROXY=true
# Set true only when TLS is terminated before the app/proxy and forwarded proto is preserved.
DJANGO_SECURE_SSL_REDIRECT=true
# Optional explicit overrides.
# By default both cookie flags inherit DJANGO_SECURE_SSL_REDIRECT.
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_LOG_LEVEL=INFO
ML_SERVICE_URL=
DSA_BOOTSTRAP_IMPORT_IF_EMPTY=false
DSA_BOOTSTRAP_XLSX_PATH=/app/bootstrap-data/EPP.xlsx
DSA_BOOTSTRAP_ALLOW_MISSING_XLSX=true
DSA_BOOTSTRAP_FAIL_ON_IMPORT_ERRORS=true
DSA_BOOTSTRAP_STATE_FILE=/var/lib/dsa/bootstrap/state.json
BOOTSTRAP_DATA_HOST_DIR=../.bootstrap-data

# Postgres
POSTGRES_DB=dsa
POSTGRES_USER=dsa
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql+psycopg2://dsa:replace-with-strong-db-password@postgres:5432/dsa
DATABASE_URL_FILE=

# Optional integrations
ALGOLIA_APPLICATION_ID=replace-me
ALGOLIA_API_KEY=replace-me
ALGOLIA_INDEX_PREFIX=DSA
ML_SERVICE_TIMEOUT=2.5
