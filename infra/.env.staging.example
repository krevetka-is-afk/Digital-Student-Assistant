# Django/web
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace-with-staging-secret
DJANGO_SECRET_KEY_FILE=
DJANGO_ALLOWED_HOSTS=staging.example,localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.example,http://staging.example
DJANGO_BEHIND_PROXY=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_LOG_LEVEL=INFO
ML_SERVICE_URL=http://ml:8000
DSA_BOOTSTRAP_IMPORT_IF_EMPTY=false
DSA_BOOTSTRAP_XLSX_PATH=/app/bootstrap-data/EPP.xlsx
DSA_BOOTSTRAP_ALLOW_MISSING_XLSX=true
DSA_BOOTSTRAP_FAIL_ON_IMPORT_ERRORS=true
DSA_BOOTSTRAP_STATE_FILE=/var/lib/dsa/bootstrap/state.json
BOOTSTRAP_DATA_HOST_DIR=../.bootstrap-data

# Email delivery
# Use console backend while SMTP credentials are absent; switch to SMTP after mailbox setup.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Digital Student Assistant <no-reply@staging.example>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@staging.example
EMAIL_HOST_PASSWORD=replace-with-staging-smtp-password
EMAIL_HOST_PASSWORD_FILE=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# Email verification
EMAIL_VERIFICATION_CODE_TTL_SECONDS=900
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Postgres
POSTGRES_DB=dsa
POSTGRES_USER=dsa
POSTGRES_PASSWORD=replace-with-staging-db-password
DATABASE_URL=postgresql+psycopg2://dsa:replace-with-staging-db-password@postgres:5432/dsa
DATABASE_URL_FILE=

# Neo4j
NEO4J_AUTH=neo4j/replace-with-staging-neo4j-password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-staging-neo4j-password

# Graph/outbox
OUTBOX_BASE_URL=http://web:8000
OUTBOX_AUTH_HEADER=
OUTBOX_TIMEOUT_SEC=10
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SEC=5
ML_ENABLE_BACKGROUND_POLLER=false
ML_INDEX_STATE_PATH=/tmp/ml-index.json
GRAPH_ENABLE_BACKGROUND_POLLER=false

# Optional integrations
ALGOLIA_APPLICATION_ID=replace-me
ALGOLIA_API_KEY=replace-me
ALGOLIA_INDEX_PREFIX=DSA
ML_SERVICE_TIMEOUT=2.5
