DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-project
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ALGOLIA_APPLICATION_ID=change-me-in-project
ALGOLIA_API_KEY=change-me-in-project
ALGOLIA_INDEX_PREFIX=SERJ
DATABASE_URL=sqlite:///db.sqlite3

# Email delivery
# Local default prints verification emails to the Django process stdout.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@digital-student-assistant.local
EMAIL_HOST=
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# Email verification
EMAIL_VERIFICATION_CODE_TTL_SECONDS=900
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

OUTBOX_SERVICE_TOKENS={"ml":"change-me-ml-token","graph":"change-me-graph-token"}
